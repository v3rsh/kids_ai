# =====================================================================
# === Core / pybotx ===
# =====================================================================
# UUID бота (получить в админке eXpress после регистрации).
BOT_ID=your-bot-uuid-here

# URL CTS-сервера (полный, со схемой).
CTS_URL=https://cts.example.com

# Секретный ключ бота (получить в админке eXpress).
BOT_SECRET_KEY=your-secret-key-here

# HUID администраторов — UUID через запятую. Первый получает системные
# алёрты (см. ADMIN_HUIDS в app/config.py).
ADMIN_HUID=first-admin-huid,second-admin-huid


# =====================================================================
# === Database (PostgreSQL) ===
# =====================================================================
# PostgreSQL поднимается контейнером `postgres` из docker-compose.yml
# (image: postgres:15-alpine, IP 172.20.0.3). Данные хранятся в named
# volume `pgdata` и переживают `docker compose down/up` и перезагрузку
# хоста; стираются только при `docker compose down -v` или явном
# `docker volume rm pgdata`.
DB_HOST=172.20.0.3
DB_PORT=5432
DB_NAME=kids_ai
DB_USER=postgres
DB_PASSWORD=your_secure_password_here


# =====================================================================
# === Web server (Starlette + uvicorn) ===
# =====================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000


# =====================================================================
# === Redis FSM ===
# =====================================================================
# Redis поднимается контейнером `redis` из docker-compose.yml
# (image: redis:7-alpine, IP 172.20.0.4). AOF-файл хранится в named
# volume `redisdata` (--appendonly yes --appendfsync everysec) —
# состояния FSM не теряются при рестарте бота/Redis/хоста.
# Переменная ОБЯЗАТЕЛЬНА: при пустом значении бот падает на старте.
REDIS_URL=redis://172.20.0.4:6379/0
# Время жизни FSM-записей (дни) — автоочистка устаревших анкет.
FSM_TTL_DAYS=30


# =====================================================================
# === Scheduler / Workers ===
# =====================================================================
# Запускать periodic jobs в этом процессе. При multi-worker деплое:
#   ENABLE_SCHEDULER=false у bot, отдельный контейнер scheduler — true.
ENABLE_SCHEDULER=false
# Количество uvicorn workers (увеличивать только при отдельном scheduler).
UVICORN_WORKERS=1
# Resource limits (опциональные оверрайды для docker-compose):
# BOT_MEM_LIMIT=2G
# REDIS_MEM_LIMIT=1G
# REDIS_MAXMEMORY=512mb
# PG_MEM_LIMIT=1G


# =====================================================================
# === Debug & Logging ===
# =====================================================================
# DEBUG=True даёт подробный traceback в /healthz и расширенные логи pybotx.
DEBUG=False
# Уровень логирования: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
# JSON-формат логов — для Docker/ELK; человекочитаемый при False.
JSON_LOGS=False


# =====================================================================
# === Moderation / Jury ===
# =====================================================================
# Модераторы, члены жюри и чат модерации в .env НЕ задаются. Управление
# полностью через discovery-флоу:
#   - не-модератор дёрнул /moderator → админу прилетает карточка
#     с профилем и кнопками «Назначить модератором / Отклонить»;
#   - не-жюри дёрнул /jury → аналогично, карточка «Назначить жюри»;
#   - бот добавлен в новый групповой чат → админу прилетает карточка
#     «Сделать этот чат чатом модерации?»;
#   - диагностика — /admin_roles, /admin_state;
#   - отзыв роли — /admin_role_revoke.
# Источник правды — БД (moderators / jury_members / app_settings).
# Никаких MODERATOR_HUIDS / JURY_HUIDS / MODERATION_CHAT_ID не нужно.


# =====================================================================
# === Jury ===
# =====================================================================
# Размер шорт-листа на пул. По умолчанию 10.
TOP_N=10
# Максимум раундов до автоматического жребия. По умолчанию 3.
JURY_ROUNDS=3
# Дедлайн одного раунда в часах (по умолчанию 48 ч — окно
# 22–29 июня размещает ровно 3 раунда).
JURY_ROUND_DEADLINE_HOURS=48
# JSON-конфиг распределения судей по пулам.
# Пустая строка = все активные судьи во всех 9 пулах
# (3 трека × 3 возрастные категории).
JURY_POOLS_CONFIG=


# =====================================================================
# === Storage & Files ===
# =====================================================================
# Каталог локального хранилища файлов конкурса.
# В контейнере — bind-mount ./data/attachments хоста (см. docker-compose.yml).
# Структура: <YYYY-MM-DD>/<01_traditional|02_ai|03_refine>/<возраст>/BR-...
ATTACHMENTS_DIR=/app/data/attachments

# Максимальный размер одного файла в мегабайтах.
MAX_FILE_SIZE_MB=10

# Режим приёма заявок по умолчанию: files | links.
# При DISK_BLOCK_PCT автопереключается в links (services/intake_mode.py).
INTAKE_MODE_DEFAULT=files

# Год конкурса — используется в формировании BR-ID (BR-{YEAR}-NNNN)
# и в имени Excel-выгрузки (см. docs/registry-spec.md).
COMPETITION_YEAR=2026

# Текст экрана «Контакты организаторов». Многострочные значения
# передаются через \n — dotenv разворачивает их в реальные переводы строк.
# Пустая строка / отсутствие переменной → используется дефолт из config.py.
# CONTACTS_TEXT="Контакты организаторов:\n\n• Организатор конкурса — команда ИБ.\n• Основной модератор — Екатерина Винокурова.\n• Резервный модератор / владелец проекта — Анастасия Иванова.\n\nПо всем вопросам пишите в чат «Безопасные рисунки — модерация»."


# =====================================================================
# === Disk monitoring ===
# =====================================================================
# Пороги мониторинга диска:
#   DISK_WARN_PCT  — предупреждение в чат модерации.
#   DISK_BLOCK_PCT — блокировка приёма + авто-переход в LINKS.
DISK_WARN_PCT=80
DISK_BLOCK_PCT=95
# Интервал фонового мониторинга в секундах. По умолчанию 1800 (30 мин);
# алёрт сам дедуплицируется (раз в 24 часа на каждый порог), снижать
# значение почти бессмысленно.
DISK_CHECK_INTERVAL_SEC=1800


# =====================================================================
# === eXpress deeplink ===
# =====================================================================
# Deeplink на бота в eXpress (кнопки в чате модерации). Не хардкодить в коде.
# EXPRESS_DEEPLINK_TEMPLATE — URL-шаблон. Плейсхолдеры: {bot_id}, {ets_id},
# {cts_url}; опционально {br_id}, {command}, {command_encoded}.
# EXPRESS_ETS_ID — параметр ets_id для Beeline (из ссылки open/profile/…).
# Если шаблон пуст — остаются текст /find в уведомлении и кнопка «📄 Карточка».
# Beeline (пример):
#   EXPRESS_DEEPLINK_TEMPLATE=https://link.buzz.beeline.ru/open/profile/{bot_id}?ets_id={ets_id}
#   EXPRESS_ETS_ID=your-ets-uuid-here
# Другие CTS:
#   EXPRESS_DEEPLINK_TEMPLATE=express://chat?bot_id={bot_id}&text={command_encoded}
EXPRESS_DEEPLINK_TEMPLATE=
EXPRESS_ETS_ID=
