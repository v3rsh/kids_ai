# ===== Bot Settings (pybotx) =====
# UUID бота (получить в админке после регистрации бота)
BOT_ID=your-bot-uuid-here

# URL CTS сервера
CTS_URL=https://cts.example.com

# Секретный ключ бота (получить в админке)
BOT_SECRET_KEY=your-secret-key-here

# HUID администраторов (UUID через запятую)
# Первый в списке получает системные уведомления
ADMIN_HUID=first-admin-huid,second-admin-huid

# ===== PostgreSQL Settings =====
# Тестовый режим (контейнер PostgreSQL, docker compose --profile test):
#   DB_HOST=172.20.0.3
# Продакшн (внешний PostgreSQL компании):
#   DB_HOST=10.x.x.x
DB_HOST=172.20.0.3
DB_PORT=5432
DB_NAME=kids_ai
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ===== Web Server Settings =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ===== Redis (FSM storage) =====
# Если задан — FSM хранится в Redis (рекомендуется для продакшна)
# Если не задан — используется SQLite (файл data/states.sqlite3)
# Тестовый режим (контейнер Redis, docker compose --profile test):
#   REDIS_URL=redis://172.20.0.4:6379/0
# Продакшн (внешний Redis):
#   REDIS_URL=redis://10.x.x.x:6379/0
REDIS_URL=redis://172.20.0.4:6379/0
# Время жизни FSM-записей в днях (автоочистка)
FSM_TTL_DAYS=30

# ===== Scheduler / Workers =====
# Запускать scheduler в этом процессе (true/false)
# Актуально только при наличии app/scheduler.py
# При multi-worker деплое: false у bot, scheduler запускается отдельным контейнером
ENABLE_SCHEDULER=false
# Количество uvicorn workers (увеличивать только при отдельном scheduler)
UVICORN_WORKERS=1
# Resource limits (для docker-compose, можно переопределить в .env)
# BOT_MEM_LIMIT=2G
# REDIS_MEM_LIMIT=512M
# REDIS_MAXMEMORY=256mb
# PG_MEM_LIMIT=1G

# ===== Debug Mode =====
# Режим отладки (True/False)
DEBUG=False

# ===== Logging Settings =====
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# JSON-формат логов (для Docker/ELK): True/False
JSON_LOGS=False

# ===== Безопасные рисунки =====
# HUID модераторов (через запятую). Прошиваются на старте бота (§5.2, §27.2).
# Пример: 11111111-1111-1111-1111-111111111111,22222222-2222-2222-2222-222222222222
MODERATOR_HUIDS=

# HUID членов жюри (через запятую). Прошиваются на старте бота (§5.4, §35.4).
JURY_HUIDS=

# UUID группового чата «Безопасные рисунки — модерация» (§19).
# Создаётся модератором, бот добавляется участником.
MODERATION_CHAT_ID=

# Каталог локального хранилища файлов конкурса (§21).
# В контейнере монтируется через именованный том attachments_volume.
ATTACHMENTS_DIR=/app/data/attachments

# Максимальный размер одного файла (§11.4, §16), в мегабайтах.
MAX_FILE_SIZE_MB=10

# Пороги мониторинга диска (§28.1):
#   DISK_WARN_PCT — предупреждение в чат модерации
#   DISK_BLOCK_PCT — блокировка приёма файлов
DISK_WARN_PCT=80
DISK_BLOCK_PCT=95
# Интервал фонового мониторинга диска в секундах (по умолчанию 30 минут).
# Сам алёрт дедуплицируется в БД, так что снижать значение почти бессмысленно.
DISK_CHECK_INTERVAL_SEC=1800

# Режим приёма заявок по умолчанию (§33.6): files | links.
# При 95% автопереключается в links (см. services/intake_mode.py).
INTAKE_MODE_DEFAULT=files

# Параметры жюри (§35):
#   TOP_N — размер шорт-листа на пул (по умолчанию 10);
#   JURY_ROUNDS — максимум раундов до жребия (по умолчанию 3);
#   JURY_ROUND_DEADLINE_HOURS — дедлайн раунда в часах (по умолчанию 48,
#     §35.6 — окно 22–29 июня = ровно 3 раунда);
#   JURY_POOLS_CONFIG — JSON-конфиг распределения судей по пулам;
#     пустая строка = все судьи во всех 9 пулах
#     (3 трека × 3 возрастные категории, см. ТЗ §35.6).
TOP_N=10
JURY_ROUNDS=3
JURY_ROUND_DEADLINE_HOURS=48
JURY_POOLS_CONFIG=

# Год конкурса — используется в формировании BR-ID (§20).
COMPETITION_YEAR=2026

# Текст экрана «Контакты организаторов» (§7). Многострочные значения
# передаются через \n — dotenv разворачивает их в реальные переводы строк.
# Пустая строка / отсутствие переменной → используется дефолт из config.py.
# CONTACTS_TEXT="Контакты организаторов:\n\n• Организатор конкурса — команда ИБ.\n• Основной модератор — Екатерина Винокурова.\n• Резервный модератор / владелец проекта — Анастасия Иванова.\n\nПо всем вопросам пишите в чат «Безопасные рисунки — модерация»."
